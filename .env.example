# ─── Service ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
# secret_key requires min 32 chars
SECRET_KEY=change-me-to-32-or-more-chars-please-ok

# ─── Auth (must match contacts-backend's JWT_SECRET) ──────
GARAGE_JWT_SECRET=change-me-must-match-contacts-backend
GARAGE_JWT_ALGORITHM=HS256

# ─── Integration ──────────────────────────────────────────
CONTACTS_BACKEND_BASE_URL=http://host.docker.internal:8080
ALLOWED_ORIGINS=http://localhost:3000

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ─── Deepgram ─────────────────────────────────────────────
DEEPGRAM_API_KEY=...
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-US

# ─── PostgreSQL (docker-compose service) ──────────────────
POSTGRES_DB=garage_copilot
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot-local-pw
DATABASE_URL=postgresql+asyncpg://copilot:copilot-local-pw@postgres:5432/garage_copilot

# ─── Redis (docker-compose service) ───────────────────────
REDIS_PASSWORD=redis-local-pw
REDIS_URL=redis://:redis-local-pw@redis:6379/0

# ─── Qdrant (docker-compose service) ──────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── AWS (optional — only needed for S3 exports) ──────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_ARTIFACTS=garage-copilot-artifacts
S3_BUCKET_RECORDINGS=garage-copilot-recordings
